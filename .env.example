# Environment Variables Configuration

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id_here
GOOGLE_OAUTH_SECRET=your_google_client_secret_here

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here
OAUTH_DOMAIN=https://your-ngrok-domain.ngrok-free.app

# Django Settings
DEBUG=True
SECRET_KEY=your_django_secret_key_here
ALLOWED_HOSTS=localhost,127.0.0.1,your-render-app.onrender.com
CSRF_TRUSTED_ORIGINS=https://your-render-app.onrender.com

# AI Speech-to-Text
# Optional: enables hosted AI transcription for interview videos.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_TRANSCRIBE_MODEL=whisper-1

# Optional: use Google Cloud Speech-to-Text before OpenAI/local Whisper.
GOOGLE_SPEECH_API_KEY=your_google_cloud_speech_api_key_here
GOOGLE_SPEECH_LANGUAGE=en-US
GOOGLE_SPEECH_MODEL=latest_long

# Razorpay Payments
RAZORPAY_KEY_ID=your_razorpay_test_or_live_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_test_or_live_key_secret_here

# Database
DB_ENGINE=mysql
DB_NAME=resume_ai_db
DB_USER=root
DB_PASSWORD=root
DB_HOST=127.0.0.1
DB_PORT=3306


# Render demo option
# Use DB_ENGINE=sqlite for a simple demo deploy, or configure MySQL/PostgreSQL separately for production persistence.


